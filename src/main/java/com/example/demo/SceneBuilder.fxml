<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="900.0" prefWidth="600.0" style="-fx-background-color: #F1F8E9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.Launcher">
   <children>
      <TextField fx:id="usernameField" layoutX="138.0" layoutY="252.0" prefHeight="45.0" prefWidth="300.0" promptText="Email" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #DADADA; -fx-padding: 10; -fx-font-size: 14;" />
      <Label alignment="CENTER" layoutX="245.0" layoutY="120.0" style="-fx-font-family: 'Berlin Sans FB Demi'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="LOGIN" />
      <Label layoutX="189.0" layoutY="177.0" style="-fx-font-size: 14; -fx-text-fill: #777777;" text="Log in to continue your journey." />
      <TextField fx:id="visiblePasswordField" layoutX="138.0" layoutY="348.0" prefHeight="45.0" prefWidth="300.0" promptText="Password" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #DADADA; -fx-padding: 10; -fx-font-size: 14;" />
      <Button layoutX="138.0" layoutY="427.0" mnemonicParsing="false" onAction="#loginButton" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-family: 'Berlin Sans FB Demi'; -fx-font-size: 20; -fx-font-weight: bold;" text="Log In" />
      <Label fx:id="loginmessage" alignment="CENTER" layoutX="138.0" layoutY="496.0" prefHeight="45.0" prefWidth="300.0" style="-fx-font-size: 13; -fx-text-fill: red; -fx-font-weight: bold;" wrapText="true" />
      <Label layoutX="138.0" layoutY="558.0" style="-fx-font-size: 13; -fx-text-fill: #777777; -fx-font-weight: bold;" text=" Don't have an account?" />
      <Label layoutX="290.0" layoutY="558.0" onMouseClicked="#showAddAccount" style="-fx-font-size: 13; -fx-text-fill: #2E7D32; -fx-font-weight: bold;" text="Sign up">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Label>
      <PasswordField fx:id="passwordField" layoutX="138.0" layoutY="348.0" prefHeight="45.0" prefWidth="300.0" promptText="Password" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #DADADA; -fx-padding: 10; -fx-font-size: 14; -fx-background-color: white;" />
      <Button fx:id="showPasswordButton" layoutX="438.0" layoutY="353.0" mnemonicParsing="false" onAction="#togglePasswordVisibility" prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: black;" text="👁" />
   </children>
</AnchorPane>
