         <font>
            <Font size="17.0" />
         </font></Label>
      <ImageView fitHeight="70.0" fitWidth="71.0" layoutX="76.0" layoutY="164.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="BackArrow" fitHeight="18.0" fitWidth="21.0" layoutX="36.0" layoutY="33.0" pickOnBounds="true" preserveRatio="true" />
      <Label fx:id="highestcategory" layoutX="286.0" layoutY="199.0">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>

    </content>

</ScrollPane>