<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="900.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.Primary3Controller">
<content>
<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="600.0" spacing="15.0" style="-fx-background-color: white;">

   <children>

      <!-- ── Title (UNCHANGED) ── -->
      <HBox minWidth="50.0" prefHeight="50.0" prefWidth="50.0" VBox.vgrow="NEVER">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="50.0" prefWidth="440.0" text="Add Activity" textFill="#2e7d32" HBox.hgrow="ALWAYS">
               <font><Font name="Berlin Sans FB Demi Bold" size="36.0" /></font>
               <HBox.margin><Insets left="75.0" top="25.0" /></HBox.margin>
            </Label>
            <!-- Next Page Button — top right -->
            <Button fx:id="nextPageButton" onAction="#handleNextPage" style="-fx-background-color: #4CAF50;                            -fx-background-radius: 20;                            -fx-font-weight: bold;                            -fx-font-size: 13px;                            -fx-cursor: hand;                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 6, 0, 0, 2);" text="Next ›" textFill="WHITE">
               <HBox.margin><Insets right="10.0" top="22.0" /></HBox.margin>
               <padding><Insets bottom="7" left="16" right="16" top="7" /></padding>
            </Button>
         </children>
      </HBox>

      <!-- ── Subtitle (UNCHANGED) ── -->
      <Label alignment="CENTER" prefHeight="10.0" prefWidth="600.0" text="What eco-friendly action did you take?" textFill="#333333" VBox.vgrow="NEVER">
         <font><Font name="System Bold" size="16.5" /></font>
         <VBox.margin><Insets left="2.0" /></VBox.margin>
      </Label>

      <!-- ── Category Grid (UNCHANGED) ── -->
      <GridPane alignment="CENTER" hgap="15.0" prefHeight="300.0" prefWidth="560.0" style="-fx-background-color: transparent; -fx-padding: 15;" vgap="15.0" VBox.vgrow="NEVER">
         <columnConstraints>
            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints halignment="CENTER" hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
         </rowConstraints>
         <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>

         <children>

            <!-- Transport (UNCHANGED) -->
            <VBox fx:id="transportVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#transportClicked" prefHeight="170.0" prefWidth="140.0" spacing="8.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@car.png" /></image>
                  </ImageView>
                  <Label fx:id="TransportLabel" alignment="BOTTOM_CENTER" prefHeight="25.0" prefWidth="160.0" text="Transport" textFill="#333333">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
            </VBox>

            <!-- Electricity (UNCHANGED) -->
            <VBox fx:id="ElectricityVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#electricityClicked" prefHeight="170.0" prefWidth="140.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;" GridPane.columnIndex="1">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@energy2.png" /></image>
                  </ImageView>
                  <Label fx:id="ElectricityLabel" alignment="BOTTOM_CENTER" prefHeight="25.0" prefWidth="160.0" text="Electricity" textFill="#333333">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
            </VBox>

            <!-- Water (UNCHANGED) -->
            <VBox fx:id="WaterVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#waterClicked" prefHeight="170.0" prefWidth="140.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;" GridPane.columnIndex="2">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@water.png" /></image>
                  </ImageView>
                  <Label fx:id="WaterLabel" alignment="BOTTOM_CENTER" prefHeight="25.0" prefWidth="160.0" text="Water" textFill="#333333">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
            </VBox>

            <!-- Waste (UNCHANGED) -->
            <VBox fx:id="WasteVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#wasteClicked" prefHeight="170.0" prefWidth="140.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;" GridPane.halignment="CENTER" GridPane.rowIndex="1">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@waste.png" /></image>
                  </ImageView>
                  <Label fx:id="WasteLabel" alignment="BOTTOM_CENTER" prefHeight="25.0" prefWidth="160.0" text="Waste" textFill="#333333">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
            </VBox>

            <!-- Food (UNCHANGED) -->
            <VBox fx:id="FoodVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#foodClicked" prefHeight="170.0" prefWidth="140.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-width: 1; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@food.png" /></image>
                  </ImageView>
                  <Label fx:id="FoodLabel" alignment="BOTTOM_CENTER" prefHeight="25.0" prefWidth="160.0" text="Food" textFill="#333333">
                     <font><Font name="System Bold" size="16.0" /></font>
                  </Label>
               </children>
               <GridPane.margin><Insets /></GridPane.margin>
            </VBox>

            <!-- Other (UNCHANGED) -->
            <VBox fx:id="OtherVBox" alignment="CENTER" maxHeight="170.0" maxWidth="140.0" onMouseClicked="#otherClicked" prefHeight="170.0" prefWidth="140.0" style="-fx-background-color: #f5f5f5; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 10; -fx-cursor: hand; -fx-border-color: green;" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                     <image><Image url="@interface.png" /></image>
                  </ImageView>
                  <Label fx:id="OtherLabel" alignment="BOTTOM_CENTER" opacity="0.85" prefHeight="25.0" prefWidth="160.0" style="-fx-font-weight: bold;" text="Other" textFill="#333333">
                     <font><Font size="16.0" /></font>
                  </Label>
               </children>
            </VBox>

         </children>
         <VBox.margin><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></VBox.margin>
      </GridPane>

      <!-- ══ INPUT SECTION (enhanced bottom) ══ -->
      <VBox spacing="0.0" style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: green; -fx-border-width: 1.5; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,100,0,0.10), 14, 0, 0, 4);">
         <VBox.margin><Insets bottom="20.0" left="24.0" right="24.0" top="0.0" /></VBox.margin>
         <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>

         <children>

            <!-- Type of Activity -->
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Select Type of Activity" textFill="#2e7d32" />
            <ComboBox fx:id="typeComboBox" prefHeight="36.0" prefWidth="999.0" promptText="Choose an activity…" style="-fx-background-color: #f9fbe7;                              -fx-background-radius: 10;                              -fx-border-radius: 10;                              -fx-border-color: #aed581;                              -fx-font-size: 13px;">
               <VBox.margin><Insets bottom="14.0" top="6.0" /></VBox.margin>
            </ComboBox>

            <!-- Value -->
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Enter Value" textFill="#2e7d32" />
            <TextField fx:id="amountField" prefHeight="36.0" prefWidth="999.0" promptText="Enter Amount / Value" style="-fx-background-color: #f9fbe7;                               -fx-background-radius: 10;                               -fx-border-color: #aed581;                               -fx-border-radius: 10;                               -fx-font-size: 13px;">
               <VBox.margin><Insets bottom="14.0" top="6.0" /></VBox.margin>
            </TextField>

            <!-- Recycled -->
            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Recycled / Reused" textFill="#2e7d32" />
            <CheckBox fx:id="recycledCheckBox" style="-fx-font-size: 13px; -fx-text-fill: #33691e;" text="Yes, this is recycled or reused material">
               <VBox.margin><Insets bottom="16.0" top="6.0" /></VBox.margin>
            </CheckBox>

            <!-- CO2 Result box -->
            <HBox alignment="CENTER" style="-fx-background-color: #e8f5e9;                          -fx-background-radius: 12;                          -fx-border-color: #a5d6a7;                          -fx-border-width: 1;                          -fx-border-radius: 12;">
               <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0" /></padding>
               <VBox.margin><Insets bottom="16.0" /></VBox.margin>
               <children>
                  <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 11px;" text="Carbon Footprint" textFill="#388e3c" />
                        <HBox alignment="BASELINE_LEFT" spacing="6.0">
                           <children>
                              <Label fx:id="resultCO2Label" style="-fx-font-size: 36px; -fx-font-weight: bold;" text="0.00" textFill="#1b5e20" />
                              <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0 0 6 0;" text="kg CO₂e" textFill="#43a047" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- Calculate Button -->
            <Button fx:id="calculateButton" onAction="#handleCalculate" prefHeight="42.0" prefWidth="999.0" style="-fx-background-color: #4CAF50;                            -fx-background-radius: 10;                            -fx-font-size: 15px;                            -fx-font-weight: bold;                            -fx-cursor: hand;                            -fx-effect: dropshadow(gaussian, rgba(0,100,0,0.30), 10, 0, 0, 3);" text="Calculate" textFill="WHITE" />

         </children>
      </VBox>

   </children>
</VBox>
</content>
</ScrollPane>
